AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Portal staff Gmail: Admin tab login (OAuth), approval emails, full permissions
ADMIN_EMAIL=loduuuss@gmail.com

# Google OAuth (required for Admin Gmail login)
# https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth — profile linking only (NOT login). Add redirect in Developer Portal → OAuth2:
#   http://localhost:3000/api/profile/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord bot — enable Server Members Intent (and Presence if using live presence) in Developer Portal
DISCORD_BOT_TOKEN=
# Optional: channel webhook URL for site chat (otherwise bot auto-creates "Lodus Chat" webhook)
# DISCORD_CHAT_WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN
NEXT_PUBLIC_DISCORD_CHANNEL_ID=
# Server-only (recommended on Vercel — read at runtime, not baked at build)
# DISCORD_CHANNEL_ID=
NEXT_PUBLIC_DISCORD_GUILD_ID=
# DISCORD_GUILD_ID=
NEXT_PUBLIC_DISCORD_INVITE_URL=


# PostgreSQL (required)
# Neon (recommended): Dashboard → Connection details
#   - App / Next.js: "Pooled connection" → DATABASE_URL (host contains -pooler)
#   - drizzle-kit push/migrate: "Direct connection" → DATABASE_URL_UNPOOLED (optional but recommended)
# Local: docker compose up -d
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=verify-full
# DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=verify-full

# Transactional email (Resend) — required in production
RESEND_API_KEY=re_xxxx
RESEND_FROM=Lodus <onboarding@yourdomain.com>
# RESEND_REPLY_TO=support@yourdomain.com
# MAIL_UNSUBSCRIBE_URL=https://yourdomain.com/profile

# Object storage for avatars — REQUIRED on Vercel (public/uploads is read-only serverless)
# Cloudflare R2: create bucket + API token, set endpoint + public URL (r2.dev or custom domain)
# S3_BUCKET=lodus
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://pub-xxxx.r2.dev
# S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com

# Discord on Vercel: set DISCORD_WORKER_MODE=true (required — embedded discord.js crashes serverless).
# Voice channel list still works via REST; optional worker below adds live "who is in VC".
# Local dev: leave unset/false to use embedded bot, or true + run npm run discord-worker.
DISCORD_WORKER_MODE=false
# Required when running npm run discord-worker (prod: same values on Vercel + Render)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# INTERNAL_API_SECRET=
# LODUS_API_URL=https://lodus-one.vercel.app

# Stripe — $1 USD donations (INR at live FX rate)
STRIPE_SECRET_KEY=

# --- Production MVP (public homepage only) ---
# Set false on production until member enrollment opens
NEXT_PUBLIC_MEMBER_AUTH_ENABLED=true
# Secret admin login path: https://yourdomain.com/admin/040903
ADMIN_LOGIN_SLUG=040903
# Footer $1 donation QR — set false for prod MVP; enable later with STRIPE_SECRET_KEY
NEXT_PUBLIC_DONATIONS_ENABLED=true
